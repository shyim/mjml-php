<mjml>
  <mj-body>
    <mj-section>
      <mj-column>
        <mj-social font-size="12px" icon-size="24px" mode="horizontal">
          <mj-social-element name="facebook" href="https://example.com">Facebook</mj-social-element>
          <mj-social-element name="twitter" href="https://example.com">Twitter</mj-social-element>
          <mj-social-element name="linkedin" href="https://example.com">LinkedIn</mj-social-element>
        </mj-social>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>
