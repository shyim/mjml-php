--MJML--
<mjml>
  <mj-head>
    <mj-attributes>
      <mj-text color="blue" />
      <mj-text font-size="40px" />
    </mj-attributes>
  </mj-head>
  <mj-body>
    <mj-section>
      <mj-column>
        <mj-text>Hello !</mj-text>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>

--HTML--
color:blue;
font-size:40px;
Hello !
